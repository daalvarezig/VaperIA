# ══════════════════════════════════════════════════════
#  VaperIA — Variables de entorno
#  Copia este archivo a .env y rellena los valores
#  NUNCA subas .env a GitHub
# ══════════════════════════════════════════════════════

# ─── EVOLUTION API ────────────────────────────────────
# Inventátela, min 20 chars. La necesitarás para configurar n8n y la PWA
EVOLUTION_API_KEY=pon_tu_clave_secreta_aqui_min20chars

# ─── n8n ─────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=cambia_esta_password

# ─── SUPABASE (solo para la PWA en el navegador) ─────
# Estas van en pwa/config.js — NO en el .env del servidor
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGci...

# ─── DOMINIO ──────────────────────────────────────────
# Subdominios que crearás en itopy.ai:
#   vaperia.itopy.ai     → PWA (panel owner)
#   evo.vaperia.itopy.ai → Evolution API
#   n8n.vaperia.itopy.ai → n8n
DOMAIN=itopy.ai
APP_PIN=1234
